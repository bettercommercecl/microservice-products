# Copiar a .env y completar valores
# cp .env.example .env

NODE_ENV=development
PORT=3333
APP_KEY=
HOST=0.0.0.0
LOG_LEVEL=info

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# Replica de lectura (opcional). Si no se definen, se usa la misma conexion que el writer.
# En Aurora, apuntar al reader endpoint para que las consultas de marcas no compitan con el sync.
# DB_READER_HOST=
# DB_READER_PORT=
# DB_READER_USER=
# DB_READER_PASSWORD=
# DB_READER_DATABASE=

# Redis (opcional). Cache de lecturas para marcas. Si no se define REDIS_HOST, el cache no se usa.
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_KEY_PREFIX=products_ms:

COUNTRY_CODE=CL

# n8n (opcional)
URL_N8N_RESERVES=
API_N8N_USER=
VALUE_API_N8N=

# Inventario por pais: ubicacion principal (sync stock, pack reserve, BC)
# INVENTORY_LOCATION_ID_CL=
# INVENTORY_LOCATION_ID_CO=
# INVENTORY_LOCATION_ID_PE=
# Inventario reserva por pais (opcional)
INVENTORY_RESERVE_ID_CL=
INVENTORY_RESERVE_ID_CO=
INVENTORY_RESERVE_ID_PE=

# Obsoleto: la sync usa el price list de BigCommerce (v3/pricelists/.../records) para paises != CL.
# USE_EXTERNAL_PRICING=

# ID del price list en BigCommerce (obligatorio si COUNTRY_CODE no es CL). Alternativa: LIST_PRICE_ID generico.
# LIST_PRICE_ID_PE=3
# LIST_PRICE_ID_CO=
# LIST_PRICE_ID=
# Purga por price list: maximo ratio excluidos/catalogo BC (default 0.85). Opcional.
# PRICELIST_PURGE_MAX_EXCLUDED_RATIO=0.9
TIMER_METAFIELD_KEY=
USE_INVENTORY_QUANTITY=

# Sizes por tienda (getSizesByProduct): IDs de categoria small/medium/big por tienda.
# Por pais: CL (napoleon, vitacura, condor, quilicura, vina, concon, concepcion, retirocondes, condes),
# PE (buenaventura, urbano, surco, miraflores, sanmiguel, sanjuan), CO (fulppi, bogota).
# Ej: ID_SMALL_NAPOLEON=123 ID_MEDIUM_NAPOLEON=124 ID_BIG_NAPOLEON=125 ...

# Filtros: ID categoria raiz (opcional)
ID_ADVANCED=

# Packs: ID categoria con productos pack en BigCommerce (opcional). Sync packs y pack reserve.
# ID_PACKS=
# Packs: key del metafield (default: packs)
PACKS_METAFIELD_KEY=

# Sync global y formateo marcas: IDs de categorias para flags booleanos.
# Si el producto tiene la categoria, el flag es true. Sin estos valores, sameday, nextday, etc. quedan en false.
# ID_PACKS: condicion para reserve en packs. ID_RESERVE: reserva y exclusion de nextday.
# ID_SAMEDAY=
# ID_NEXTDAY=
# ID_24HORAS=
# ID_FREE_SHIPPING=
# ID_PICKUP_IN_STORE=
# ID_TURBO=
# ID_RESERVE=
# ID_PACKS=
# PERCENT_DISCOUNT_TRANSFER_PRICE=2

# Copiar a .env y completar valores
# cp .env.example .env

NODE_ENV=development
PORT=3333
APP_KEY=
HOST=0.0.0.0
LOG_LEVEL=info

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# Replica de lectura (opcional). Si no se definen, se usa la misma conexion que el writer.
# En Aurora, apuntar al reader endpoint para que las consultas de marcas no compitan con el sync.
# DB_READER_HOST=
# DB_READER_PORT=
# DB_READER_USER=
# DB_READER_PASSWORD=
# DB_READER_DATABASE=

# Redis (opcional). Cache de lecturas para marcas. Si no se define REDIS_HOST, el cache no se usa.
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_KEY_PREFIX=products_ms:

COUNTRY_CODE=CL

# n8n (opcional)
URL_N8N_RESERVES=
API_N8N_USER=
VALUE_API_N8N=

# Inventario por pais (opcional)
INVENTORY_RESERVE_ID_CL=
INVENTORY_RESERVE_ID_CO=
INVENTORY_RESERVE_ID_PE=

USE_EXTERNAL_PRICING=
TIMER_METAFIELD_KEY=
USE_INVENTORY_QUANTITY=
STORE_SIZES=

# Filtros: ID categoria raiz (opcional)
ID_ADVANCED=

# Packs: ID categoria con productos pack en BigCommerce (opcional)
PACKS_CATEGORY_ID=
# Packs: key del metafield (default: packs)
PACKS_METAFIELD_KEY=
